@using DestekTalebiYonetimi.Data

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DestekTalebiYonetimi</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DestekTalebiYonetimi.styles.css" asp-append-version="true" />
</head>
<body>

<header>
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">

            <a class="navbar-brand d-flex align-items-center"
               asp-controller="Home"
               asp-action="Index">

                <img src="~/images/cinarkent-logo.png"
                     alt="Çınarkent Belediyesi"
                     width="100"
                     height="100"
                     class="me-2" />

                <div>
                    <div class="fw-bold">
                        Çınarkent Belediyesi
                    </div>
                    <small class="text-muted">
                        Bilgi İşlem Destek Sistemi
                    </small>
                </div>
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbar">

                @if (Context.Session.GetString("KullaniciAdi") != null)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Ana Sayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Destek"
                               asp-action="Index">
                                Destek Talepleri
                            </a>
                        </li>
                    </ul>
                }

                @if (Context.Session.GetString("KullaniciAdi") != null)
                {
                    <div class="dropdown me-3">
                        <button class="btn btn-outline-secondary position-relative"
                                type="button"
                                data-bs-toggle="dropdown">
                            🔔
                            <span id="bildirimSayisi"
                                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end" style="width:420px;">
                            <li>
                                <h6 class="dropdown-header">
                                    Bildirimler
                                </h6>
                            </li>
                            
                            <!-- HATA DÜZELTİLDİ: div yerine iç içe geçebilen ul yapısı veya doğrudan kapsayıcı bir li kullanıldı -->
                            <li id="bildirimKonteyner">
                                <ul id="bildirimListesi" class="list-unstyled mb-0">
                                    <li>
                                        <span class="dropdown-item-text">
                                            Yükleniyor...
                                        </span>
                                    </li>
                                </ul>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Bildirim"
                                   asp-action="Index">
                                    📄 Tümünü Gör
                                </a>
                            </li>
                        </ul>
                    </div>

                    <span class="me-3 fw-semibold">
                        👤 @Context.Session.GetString("AdSoyad")
                    </span>

                    <a class="btn btn-outline-danger btn-sm"
                       asp-controller="Account"
                       asp-action="Logout">
                        Çıkış Yap
                    </a>
                }
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        © 2026 - Destek Talebi Yönetimi
    </div>
</footer>
<div class="toast-container position-fixed bottom-0 end-0 p-3">

    <div id="bildirimToast"
         class="toast text-bg-primary border-0"
         role="alert">

        <div class="d-flex">

            <div class="toast-body">
                🔔 Yeni bildiriminiz var.
            </div>

            <button type="button"
                    class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast">
            </button>

        </div>

    </div>

</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

<script>
// Sadece kullanıcı giriş yapmışsa SignalR ve bildirimleri çalıştır
@if (Context.Session.GetString("KullaniciAdi") != null)
{
    <text>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .build();

   connection.on("YeniBildirim", function () {

    bildirimleriYukle();

    const toastElement = document.getElementById("bildirimToast");

    const toast = new bootstrap.Toast(toastElement);

    toast.show();
    const audio = new Audio("/sounds/ding.mp3");
audio.play();

});
    connection.start()
        .then(() => console.log("SignalR bağlandı"))
        .catch(err => console.error(err));

    async function bildirimleriYukle() {
        const liste = document.getElementById("bildirimListesi");
        const sayi = document.getElementById("bildirimSayisi");

        if (!liste || !sayi) return;

        try {
            const response = await fetch("/Bildirim/SonBildirimler");
            const data = await response.json();

            sayi.innerText = data.length;

            let html = "";

            if (data.length === 0) {
                html = `
                <li>
                    <span class="dropdown-item-text">
                        Bildirim bulunmuyor.
                    </span>
                </li>`;
            } else {
                data.forEach(x => {
                html += `
<li>
    <a class="dropdown-item bildirim-link text-wrap py-3"
       style="white-space: normal;"
       href="/Destek/Detay/${x.destekTalebiId}"
       data-id="${x.id}">

        <div class="fw-semibold mb-1">
            ${x.okundu ? "🔔" : "🔵 Yeni Bildirim"}
        </div>

        <div class="small">
            ${x.mesaj}
        </div>

        <div class="text-muted mt-2" style="font-size:12px;">
            🕒 ${new Date(x.tarih).toLocaleString("tr-TR")}
        </div>

    </a>
</li>`;
                });
            }

            liste.innerHTML = html;

            // Kalan tıklama olaylarını bağlama (Event Listener)
            document.querySelectorAll(".bildirim-link").forEach(link => {
                link.addEventListener("click", async function (e) {
                    const id = this.dataset.id;
                    try {
                        await fetch("/Bildirim/OkunduYap?id=" + id, {
                            method: "POST"
                        });
                    } catch (err) {
                        console.error("Bildirim okundu işaretlenemedi:", err);
                    }
                });
            });

        } catch (error) {
            console.error("Bildirimler yüklenirken hata oluştu:", error);
        }
    }

    // Sayfa açıldığında ilk yükleme
    bildirimleriYukle();
    </text>
}
</script>

</body>
</html>