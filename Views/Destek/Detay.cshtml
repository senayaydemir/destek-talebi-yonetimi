@model DestekTalebiYonetimi.Models.DestekDetayViewModel

@{
    ViewData["Title"] = "Destek Talebi Detayı";
}
<h4 style="color:red">
Rol: @Context.Session.GetString("Rol")
</h4>
<h2>Destek Talebi Detayı</h2>
<p><strong>Rol:</strong> @Context.Session.GetString("Rol")</p>

<div class="mb-3">
    <a class="btn btn-secondary" asp-controller="Destek" asp-action="Index">
        Listeye Dön
    </a>
</div>

<div class="row">

    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong>Talep Bilgileri</strong>
            </div>

            <div class="card-body">
                <h4>@Model.Talep.Baslik</h4>

                <hr />

                <p><strong>Talep No:</strong> @Model.Talep.Id</p>

                <p>
                    <strong>Açıklama:</strong><br />
                    @Model.Talep.Aciklama
                </p>

                <p><strong>Birim:</strong> @Model.Talep.Birim</p>

                <p><strong>Talep Eden Personel:</strong> @Model.Talep.TalepEden</p>

                <p><strong>Dahili Numara:</strong> @Model.Talep.DahiliNumara</p>

                <p><strong>İlgili Sistem:</strong> @Model.Talep.IlgiliSistem</p>

                <p><strong>Talep Türü:</strong> @Model.Talep.TalepTuru</p>

                <p>
                    <strong>Öncelik:</strong>

                    @if (Model.Talep.Oncelik == "Acil")
                    {
                        <span class="badge bg-danger">Acil</span>
                    }
                    else if (Model.Talep.Oncelik == "Yüksek")
                    {
                        <span class="badge bg-warning text-dark">Yüksek</span>
                    }
                    else if (Model.Talep.Oncelik == "Normal")
                    {
                        <span class="badge bg-primary">Normal</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Düşük</span>
                    }
                </p>

                <p>
                    <strong>Oluşturulma Tarihi:</strong>
                    @Model.Talep.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")
                </p>
@if (Model.Dosyalar.Any())
{
    <hr />

    <h5>📎 Ekli Dosyalar</h5>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Dosya Adı</th>
                <th>Tür</th>
                <th>Boyut</th>
                <th>Yüklenme Tarihi</th>
                <th style="width:180px;">İşlem</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var dosya in Model.Dosyalar)
        {
            <tr>

                <td>@dosya.DosyaAdi</td>

                <td>@dosya.DosyaTuru</td>

                <td>@($"{dosya.DosyaBoyutu / 1024.0:F2} KB")</td>

                <td>@dosya.YuklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>

                <td>

                    <a href="@dosya.DosyaYolu"
                       target="_blank"
                       class="btn btn-primary btn-sm">
                        👁 Görüntüle
                    </a>

                    <a href="@dosya.DosyaYolu"
                       download
                       class="btn btn-success btn-sm">
                        ⬇ İndir
                    </a>

                </td>

            </tr>

            @if (dosya.DosyaTuru == ".jpg" ||
                 dosya.DosyaTuru == ".jpeg" ||
                 dosya.DosyaTuru == ".png" ||
                 dosya.DosyaTuru == ".gif" ||
                 dosya.DosyaTuru == ".webp")
            {
                <tr>
                    <td colspan="5">

                        <img src="@dosya.DosyaYolu"
                             class="img-fluid rounded border mt-2"
                             style="max-height:350px;" />

                    </td>
                </tr>
            }

        }

        </tbody>

    </table>
}

            </div>
        </div>
    </div>

@if (Context.Session.GetString("Rol") == "BilgiIslem")
{
    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong>Çözüm Süreci</strong>
            </div>

            <div class="card-body">

                <p>
                    <strong>Mevcut Durum:</strong>

                    @if (Model.Talep.Durum == "Bekliyor")
                    {
                        <span class="badge bg-warning text-dark">Bekliyor</span>
                    }
                    else if (Model.Talep.Durum == "İşlemde")
                    {
                        <span class="badge bg-info text-dark">İşlemde</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Çözüldü</span>
                    }
                </p>

                @if (Model.Talep.Durum == "Bekliyor")
                {
                    <div class="alert alert-warning">
                        Bu destek talebi henüz işleme alınmamıştır.
                    </div>

                    <a class="btn btn-warning w-100 mb-2"
                       asp-controller="Destek"
                       asp-action="IslemeAl"
                       asp-route-id="@Model.Talep.Id">
                         İşleme Al
                    </a>
                }
                else if (Model.Talep.Durum == "İşlemde")
                {
                    <div class="alert alert-info">
                        Bu destek talebi bilgi işlem tarafından incelenmektedir.
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        Bu destek talebi çözüme kavuşturulmuştur.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Talep.CozumAciklamasi))
                {
                    <div class="mt-3">
                        <strong>Çözüm Açıklaması:</strong>

                        <div class="border rounded p-3 mt-2 bg-light">
                            @Model.Talep.CozumAciklamasi
                        </div>
                    </div>
                }

                @if (Model.Talep.Durum != "Çözüldü")
                {
                    <hr />

                    <form asp-controller="Destek" asp-action="CozulduYap" method="post">

                        <input type="hidden" name="id" value="@Model.Talep.Id" />

                        <div class="mb-3">
                            <label class="form-label">Çözüm Açıklaması</label>

                            <textarea name="cozumAciklamasi"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Örn: Kullanıcının hesabı aktif hale getirildi ve giriş kontrolü sağlandı."></textarea>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            Çözüldü Yap
                        </button>

                    </form>
                }

            </div>
        </div>
    </div>
}
else
{
    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-header bg-light">
                <strong>Talep Durumu</strong>
            </div>

            <div class="card-body">

                <p>
                    <strong>Durum:</strong>

                    @if (Model.Talep.Durum == "Bekliyor")
                    {
                        <span class="badge bg-warning text-dark">Bekliyor</span>
                    }
                    else if (Model.Talep.Durum == "İşlemde")
                    {
                        <span class="badge bg-info text-dark">İşlemde</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Çözüldü</span>
                    }
                </p>

                @if (!string.IsNullOrWhiteSpace(Model.Talep.CozumAciklamasi))
                {
                    <hr />

                    <strong>Bilgi İşlem Açıklaması</strong>

                    <div class="border rounded p-3 mt-2 bg-light">
                        @Model.Talep.CozumAciklamasi
                    </div>
                }

            </div>
        </div>
    </div>
}

</div>
<hr />

<div class="card mt-4">
    <div class="card-header bg-dark text-white">
        <strong>İşlem Geçmişi</strong>
    </div>

    <div class="card-body">

        @if (Model.Loglar.Any())
        {
            <table class="table table-striped">

                <thead>

                    <tr>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                    </tr>

                </thead>

                <tbody>

                @foreach (var log in Model.Loglar)
                {
                    <tr>
                        <td>@log.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@log.KullaniciAdi</td>
                        <td>@log.Islem</td>
                    </tr>
                }

                </tbody>

            </table>
        }
        else
        {
            <div class="alert alert-secondary">
                Bu talep için henüz işlem kaydı bulunmamaktadır.
            </div>
        }

    </div>
</div>
<hr />

<div class="card mt-4">

    <div class="card-header bg-primary text-white">
        <strong>💬 Canlı Sohbet</strong>
    </div>

    <div class="card-body">

    @if (Model.Mesajlar.Any())
{
    @foreach (var mesaj in Model.Mesajlar)
    {
        var benimMesajim = mesaj.Gonderen == (string?)ViewBag.KullaniciAdi;

        <div class="d-flex @(benimMesajim ? "justify-content-end" : "justify-content-start") mb-3">

            <div class="p-3 rounded shadow-sm"
                 style="max-width:70%; background-color:@(benimMesajim ? "#DCF8C6" : "#F1F1F1");">

                <div class="fw-bold mb-1">
                    @mesaj.Gonderen
                </div>

                <div>
                    @mesaj.MesajMetni
                </div>

                <div class="text-end text-muted mt-2" style="font-size:12px;">
                    @mesaj.Tarih.ToString("HH:mm")
                </div>

            </div>

        </div>
    }
}
else

        {
            <div class="alert alert-light">
                Henüz mesaj bulunmuyor.
            </div>
        }

        <hr />

        <form asp-controller="Destek"
              asp-action="MesajGonder"
              method="post">

            <input type="hidden"
                   name="destekTalebiId"
                   value="@Model.Talep.Id" />

            <div class="mb-3">

                <textarea class="form-control"
                          name="mesaj"
                          rows="3"
                          placeholder="Mesajınızı yazın..."></textarea>

            </div>

            <button class="btn btn-primary">
                Gönder
            </button>

        </form>

    </div>

</div>