@model DestekTalebiYonetimi.Models.DestekTalebi

@{
    ViewData["Title"] = "Yeni Destek Talebi";
}

<h2>Yeni Destek Talebi Oluştur</h2>
<p><strong>Giriş yapan kullanıcı:</strong> @ViewBag.Kullanici</p>
<p class="text-muted">
    Sistem girişi, kullanıcı yetkisi, uygulama hatası ve belediye otomasyonlarında yaşanan destek ihtiyaçları için talep oluşturabilirsiniz.
</p>

<form asp-controller="Destek" asp-action="Ekle" method="post" enctype="multipart/form-data">

    <div class="mb-3">
        <label asp-for="Baslik" class="form-label">Talep Başlığı</label>
        <input asp-for="Baslik" class="form-control" placeholder="Örn: Sisteme giriş yapamıyorum" />
        <span asp-validation-for="Baslik" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Aciklama" class="form-label">Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control" rows="4"
                  placeholder="Örn: Şifremi doğru girmeme rağmen sistem hata veriyor. Giriş ekranında kullanıcı bulunamadı uyarısı alıyorum."></textarea>
        <span asp-validation-for="Aciklama" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Birim" class="form-label">Birim</label>
        <select asp-for="Birim" class="form-select">
            <option value="">Birim seçiniz</option>
            <option value="Bilgi İşlem">Bilgi İşlem</option>
            <option value="Mali Hizmetler">Mali Hizmetler</option>
            <option value="İnsan Kaynakları">İnsan Kaynakları</option>
            <option value="Yazı İşleri">Yazı İşleri</option>
            <option value="Fen İşleri">Fen İşleri</option>
            <option value="İmar ve Şehircilik">İmar ve Şehircilik</option>
            <option value="Destek Hizmetleri">Destek Hizmetleri</option>
            <option value="Kültür ve Sosyal İşler">Kültür ve Sosyal İşler</option>
            <option value="Diğer">Diğer</option>
        </select>
        <span asp-validation-for="Birim" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TalepEden" class="form-label">Talep Eden Personel</label>
        <input asp-for="TalepEden" class="form-control" placeholder="Örn: Ayşe Yılmaz" />
    </div>

    <div class="mb-3">
        <label asp-for="DahiliNumara" class="form-label">Dahili Numara</label>
        <input asp-for="DahiliNumara" class="form-control" placeholder="Örn: 1234" />
    </div>

    <div class="mb-3">
        <label asp-for="IlgiliSistem" class="form-label">İlgili Sistem</label>
        <select asp-for="IlgiliSistem" class="form-select">
            <option value="EBYS">EBYS</option>
            <option value="Belediye Otomasyon Sistemi">Belediye Otomasyon Sistemi</option>
            <option value="Personel Sistemi">Personel Sistemi</option>
            <option value="Muhasebe Sistemi">Muhasebe Sistemi</option>
            <option value="E-İmza Sistemi">E-İmza Sistemi</option>
            <option value="E-Posta">E-Posta</option>
            <option value="Web Portal">Web Portal</option>
            <option value="Diğer">Diğer</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="TalepTuru" class="form-label">Talep Türü</label>
        <select asp-for="TalepTuru" class="form-select">
            <option value="Sistem Girişi">Sistem Girişi</option>
            <option value="Şifre / Kullanıcı Problemi">Şifre / Kullanıcı Problemi</option>
            <option value="Yetki Talebi">Yetki Talebi</option>
            <option value="Uygulama Hatası">Uygulama Hatası</option>
            <option value="E-İmza Problemi">E-İmza Problemi</option>
            <option value="Veri Görüntüleme Sorunu">Veri Görüntüleme Sorunu</option>
            <option value="Diğer">Diğer</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Oncelik" class="form-label">Öncelik</label>
        <select asp-for="Oncelik" class="form-select">
            <option value="Düşük">Düşük</option>
            <option value="Normal" selected>Normal</option>
            <option value="Yüksek">Yüksek</option>
            <option value="Acil">Acil</option>
        </select>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">📎 Dosya Ekle</label>
        
        <div id="dropArea" class="border border-2 rounded p-4 text-center bg-light" style="cursor:pointer;">
            <h5>📂 Dosyaları buraya sürükleyip bırakın</h5>
            <p class="text-muted mb-2">veya</p>
            <button type="button" id="btnDosyaSec" class="btn btn-primary">Dosya Seç</button>
            <input type="file" id="dosyaInput" name="dosyalar" multiple hidden />
            
            <div class="small text-muted mt-3">
                Desteklenen Dosyalar: JPG, PNG, PDF, DOCX, XLSX
            </div>
        </div>

        <div id="dosyaListesi" class="mt-3"></div>
        <small class="text-muted d-block mt-2">
            Ekran görüntüsü, PDF, Word veya Excel dosyası yükleyebilirsiniz.
        </small>
    </div>

    <button type="submit" class="btn btn-primary">
        Talebi Kaydet
    </button>

    <a class="btn btn-secondary" asp-controller="Destek" asp-action="Index">
        Listeye Dön
    </a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const dosyaInput = document.getElementById("dosyaInput");
        const btnDosyaSec = document.getElementById("btnDosyaSec");
        const dosyaListesi = document.getElementById("dosyaListesi");
        const dropArea = document.getElementById("dropArea");

        let secilenDosyalar = [];

        // Tarayıcının sürüklenen dosyayı yeni sekmede açma refleksini global olarak engelle
        window.addEventListener("dragover", function (e) {
            e.preventDefault();
        }, false);

        window.addEventListener("drop", function (e) {
            e.preventDefault();
        }, false);

        // Dosya Seç butonuna tıklanınca tetikleme (üst elementlere yayılmasını engelledik)
        btnDosyaSec.addEventListener("click", function (e) {
            e.stopPropagation();
            dosyaInput.click();
        });

        // Alana tıklandığında (buton haricinde bir yere tıklandıysa) dosya penceresini aç
        dropArea.addEventListener("click", function (e) {
            if (e.target !== btnDosyaSec) {
                dosyaInput.click();
            }
        });

        // Dosya normal yolla (pencereden) seçildiğinde listenin güncellenmesi
        dosyaInput.addEventListener("change", function () {
            for (let i = 0; i < this.files.length; i++) {
                secilenDosyalar.push(this.files[i]);
            }
            inputuGuncelle();
            listeyiGuncelle();
        });

        // Sürükle-bırak olayları için varsayılan tarayıcı engellemeleri
        ["dragenter", "dragover", "dragleave", "drop"].forEach(eventName => {
            dropArea.addEventListener(eventName, function (e) {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        // Sürüklerken görsel feedback efektleri
        dropArea.addEventListener("dragover", function () {
            dropArea.classList.add("border-primary");
            dropArea.classList.add("bg-white");
        });

        dropArea.addEventListener("dragleave", function () {
            dropArea.classList.remove("border-primary");
            dropArea.classList.remove("bg-white");
        });

        // Sürüklenen dosya bırakıldığında listeye eklenmesi
        dropArea.addEventListener("drop", function (e) {
            dropArea.classList.remove("border-primary");
            dropArea.classList.remove("bg-white");

            const yeniDosyalar = e.dataTransfer.files;
            
            if (yeniDosyalar.length > 0) {
                for (let i = 0; i < yeniDosyalar.length; i++) {
                    secilenDosyalar.push(yeniDosyalar[i]);
                }
                inputuGuncelle();
                listeyiGuncelle();
            }
        });

        // Seçilen dosyaların HTML listesini oluşturur
        function listeyiGuncelle() {
            dosyaListesi.innerHTML = "";

            secilenDosyalar.forEach(function (dosya, index) {
                dosyaListesi.innerHTML += `
                    <div class="card mb-2">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                📄 <strong>${dosya.name}</strong><br>
                                <small>${(dosya.size / 1024).toFixed(2)} KB</small>
                            </div>
                            <button type="button" class="btn btn-danger btn-sm" onclick="dosyaSil(${index})">
                                🗑 Kaldır
                            </button>
                        </div>
                    </div>
                `;
            });
        }

        // Seçilen dosyaları, controller'a gidecek olan gizli input.files alanıyla senkronize eder
        function inputuGuncelle() {
            const dataTransfer = new DataTransfer();
            secilenDosyalar.forEach(function (x) {
                dataTransfer.items.add(x);
            });
            dosyaInput.files = dataTransfer.files;
        }

        // Listeden dosya silme
        window.dosyaSil = function (index) {
            secilenDosyalar.splice(index, 1);
            inputuGuncelle();
            listeyiGuncelle();
        }
    </script>
}