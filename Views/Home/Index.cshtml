@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center mb-4">
    <h1 class="display-5">Destek Talebi Yönetimi</h1>
    <p class="lead">
        Belediye personelinin sistem, giriş, yetki ve uygulama kaynaklı destek taleplerini takip etmek için geliştirilmiştir.
    </p>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Talep Oluştur</h5>
                <p class="card-text">
                    Personel yaşadığı sistemsel problemi destek talebi olarak iletebilir.
                </p>
                <a class="btn btn-primary" asp-controller="Destek" asp-action="Ekle">
                    Yeni Talep Oluştur
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Talepleri Takip Et</h5>
                <p class="card-text">
                    Oluşturulan talepler bekliyor, işlemde ve çözüldü durumlarına göre takip edilir.
                </p>
                <a class="btn btn-secondary" asp-controller="Destek" asp-action="Index">
                    Talepleri Görüntüle
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center mb-3">
            <div class="card-body">
                <h5 class="card-title">Çözüm Süreci</h5>
                <p class="card-text">
                    Bilgi işlem personeli talepleri değerlendirir, işleme alır ve çözüm açıklaması ekler.
                </p>
                <a class="btn btn-success" asp-controller="Destek" asp-action="Index">
                    Süreci Yönet
                </a>
            </div>
        </div>
    </div>
</div>